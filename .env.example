# Copy to apps/api/.env and apps/web/.env.local as needed.

# API (apps/api)
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PORT=4000
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# Web (apps/web — use NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Promote a user to admin after first signup (apps/api)
# SEED_ADMIN_USER_ID=<supabase-user-uuid>
# npm run db:seed -w apps/api
